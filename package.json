{
  "name": "lions-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://theadscreators.github.io/lions/",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"const fs = require('fs'); fs.copyFileSync('dist/index.html', 'dist/404.html'); if (!fs.existsSync('dist/agenda')) fs.mkdirSync('dist/agenda'); fs.copyFileSync('dist/index.html', 'dist/agenda/index.html');\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "vite": "^8.0.10",
    "vite-node": "^6.0.0"
  }
}
